# Build/deploy environment. Copy to .env (gitignored) and fill in as needed.

# BFF proxy base URL (build-time, optional) — overrides the defaults baked into the app:
#   prod -> https://poe2-planner-bff.pages.dev,  dev -> http://localhost:8787
# Users can also override at runtime in the app (localStorage 'poe2-bff').
VITE_BFF_BASE=

# Cloudflare token for non-interactive `npm run deploy:bff` (else use `wrangler login`).
# Needs the "Cloudflare Pages: Edit" permission (dash.cloudflare.com -> My Profile -> API Tokens).
# Never commit the real value.
CLOUDFLARE_API_TOKEN=

# Cloudflare account id that owns the Pages project (Workers & Pages -> Account ID in the dashboard).
# Required by `npm run deploy:bff`.
CLOUDFLARE_ACCOUNT_ID=

# Optional: local BFF dev-server port for `npm run serve:bff` (server/dev.mjs). Defaults to 8787.
PORT=

# Data-pipeline ONLY (the art steps of `npm run data:refresh`) — the shipped app never reads these:
#   POE2_INSTALL — path to a local Path of Exile 2 install to extract game art from. Unset → the scripts
#     fetch from GGG's CDN instead (the default on CI or any machine without the game).
#   POE2_OFFLINE — set to 1 to force the unique-icon build to use only the cached CDN assets (no network).
POE2_INSTALL=
POE2_OFFLINE=
