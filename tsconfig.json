{
  // Typecheck only — `npm run build` runs `tsc --noEmit`; Vite/esbuild does the actual transpile.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler", // Vite resolves imports (extensionless, package "exports")
    "useDefineForClassFields": true,
    "resolveJsonModule": true, // src/data/*.json imported as modules
    "isolatedModules": true, // each file transpiled in isolation (esbuild/Vite)
    "types": ["vite/client", "node"], // import.meta.env + asset modules; node for tests/scripts

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true, // indexed access is T | undefined — guard before use
    "exactOptionalPropertyTypes": false, // deliberately off: too strict for optional DOM/option props

    "skipLibCheck": true
  },
  "include": ["src", "tests"]
}
