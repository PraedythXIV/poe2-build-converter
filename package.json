{
  "name": "poe2-build-converter",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "description": "PoE 2 - Sweet Vision — browser-based converter & planner: Path of Building 2 export -> PoE2 .build (Build Planner) file. Not affiliated with or endorsed by Grinding Gear Games.",
  "license": "MIT",
  "author": "PraedythXIV",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test:coverage": "vitest run --coverage",
    "preview": "vite preview",
    "serve:bff": "node server/dev.mjs",
    "deploy:bff": "node scripts/deploy-bff.mjs",
    "fetch-data": "node scripts/fetch-data.mjs",
    "data:patch": "node scripts/patch-version.mjs",
    "data:extract": "node scripts/extract-tables.mjs",
    "data:tree": "node scripts/build-tree-graph.mjs",
    "data:conqueror": "node scripts/build-conqueror-data.mjs",
    "data:atlas": "node scripts/build-atlas-graph.mjs",
    "data:atlas-bg": "node scripts/build-atlas-bg.mjs",
    "data:atlas-icons": "node scripts/build-atlas-icons.mjs",
    "data:genesis-csd": "node scripts/fetch-genesis-csd.mjs",
    "data:genesis": "node scripts/build-genesis-graph.mjs",
    "data:genesis-crafting": "node scripts/build-genesis-crafting.mjs",
    "data:genesis-icons": "node scripts/build-genesis-icons.mjs",
    "data:genesis-bg": "node --max-old-space-size=6144 scripts/build-genesis-bg.mjs",
    "data:emotions": "node scripts/build-emotions.mjs",
    "data:emotion-icons": "node scripts/build-emotion-icons.mjs",
    "data:jewel-radii": "node scripts/build-jewel-radii.mjs",
    "data:atlas-masters": "node scripts/build-atlas-masters.mjs",
    "data:atlas-master-icons": "node scripts/build-atlas-master-icons.mjs",
    "data:atlas-master-portraits": "node scripts/build-atlas-master-portraits.mjs",
    "data:icons": "node scripts/build-item-icons.mjs",
    "data:unique-icons": "node scripts/build-unique-icons.mjs",
    "data:psg-verify": "node scripts/decode-psg.mjs --verify",
    "data:refresh": "node scripts/refresh-data.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:licenses": "node scripts/check-licenses.mjs",
    "check:provenance": "node scripts/check-provenance.mjs",
    "check:dedupe": "jscpd src scripts server tests index.html vite.config.ts vitest.config.ts eslint.config.js && node scripts/check-uikit.mjs",
    "check:compliance": "npm run check:licenses && npm run check:provenance",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"{src,scripts,server,tests}/**/*.{ts,mjs,mts,css}\" \"*.{ts,js}\"",
    "format:check": "prettier --check \"{src,scripts,server,tests}/**/*.{ts,mjs,mts,css}\" \"*.{ts,js}\""
  },
  "dependencies": {
    "pako": "^3.0.0"
  },
  "devDependencies": {
    "@codecov/vite-plugin": "^2.0.1",
    "@eslint/js": "^10.0.1",
    "@jsquash/webp": "^1.5.0",
    "@types/node": "^26.0.1",
    "@types/pako": "^2.0.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jscpd": "5.0.11",
    "jsdom": "^29.1.1",
    "pathofexile-dat": "^15.2.0",
    "pathofexile-dat-schema": "^8.0.0",
    "prettier": "^3.9.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.9"
  },
    "//overrides": "@codecov/vite-plugin declares a Vite 4-6 peer but works on our Vite 8 (verified building on Rolldown); the override feeds it our own vite so npm ci resolves without weakening peer checks project-wide. Remove when the plugin's peer range catches up.",
  "overrides": {
    "@codecov/vite-plugin": {
      "vite": "$vite"
    }
  }
}
